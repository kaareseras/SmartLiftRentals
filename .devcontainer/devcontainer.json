{
  "name": "SmartLiftRentals",
  "dockerComposeFile": [
    "../docker-compose.dev.yml"
  ],
  "service": "backend-dev",
  "workspaceFolder": "/workspace",
  "runServices": [
    "backend-dev",
    "postgres",
    "mosquitto",
    "redis",
    "frontend-dev"
  ],
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "Vue.volar",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
